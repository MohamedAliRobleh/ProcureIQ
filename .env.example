# ProcureIQ environment variables
#
# Copy this file to `.env` and fill in your values. NEVER commit the real `.env`.
#
# Only DATABASE_URL + the two Clerk keys are REQUIRED to run the app. Every other
# integration is KEY-OPTIONAL: without its key the feature degrades gracefully
# (the related endpoint returns 503 and the UI says it isn't configured), and the
# full test suite stays green. Add keys as you enable each integration.

# ── Required ──────────────────────────────────────────────────────────────────

# Neon Postgres connection string (get yours at console.neon.tech).
# After setting this, apply the schema with: npx prisma migrate deploy
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Clerk auth (get yours at dashboard.clerk.com). Enable Organizations in the
# Clerk dashboard for the multi-org / admin / permissions features to work.
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."   # frontend (exposed; safe to ship)
CLERK_SECRET_KEY="sk_test_..."             # backend only — never expose

# Slug of the shared demo org that enables the read-only visitor sandbox +
# guided tour (client-side only). Defaults to procureiq-demo.
VITE_DEMO_ORG_SLUG="procureiq-demo"

# ── Optional integrations (key-optional; 503 + graceful UI when unset) ─────────

# Anthropic — AI assistant + contract summaries (console.anthropic.com).
ANTHROPIC_API_KEY="sk-ant-..."

# Cloudinary — contract file uploads (cloudinary.com → dashboard → API Keys).
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"    # backend only — never expose

# Brevo — transactional email / reminders (brevo.com → SMTP & API → API Keys).
# BREVO_SENDER_EMAIL must be a verified sender/domain in your Brevo account,
# otherwise sends fail with 502. BREVO_SENDER_NAME is optional (defaults to "ProcureIQ").
BREVO_API_KEY="xkeysib-..."
BREVO_SENDER_EMAIL="noreply@yourdomain.com"
BREVO_SENDER_NAME="ProcureIQ"

# Stripe — demo billing checkout (dashboard.stripe.com → Developers → API keys,
# and Products → create Pro/Enterprise prices → copy their price IDs).
# Without these the Billing page's Upgrade flow returns 503 ("Billing isn't set up yet").
# A webhook to persist plan changes is not implemented yet (current plan is fixed to "free").
STRIPE_SECRET_KEY="sk_test_..."            # backend only — never expose
STRIPE_PRICE_PRO="price_..."               # Stripe price ID for the Pro plan
STRIPE_PRICE_ENTERPRISE="price_..."        # Stripe price ID for the Enterprise plan

# Public base URL of the deployed app — used to build Stripe Checkout
# success/cancel redirect URLs. Defaults to http://localhost:5173 if unset, so
# set it in your Vercel project env for preview/production before going live.
APP_URL="https://your-app.vercel.app"
