# Neon Postgres connection string (get yours at console.neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Clerk (get yours at dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Anthropic API key for AI features (get yours at console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-..."

# Cloudinary (get yours at cloudinary.com → dashboard → API Keys)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Brevo transactional email (get yours at brevo.com → SMTP & API → API Keys;
# BREVO_SENDER_EMAIL must be a verified sender/domain in your Brevo account)
BREVO_API_KEY="xkeysib-..."
BREVO_SENDER_EMAIL="noreply@yourdomain.com"
BREVO_SENDER_NAME="ProcureIQ"
